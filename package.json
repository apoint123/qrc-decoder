{
	"name": "qrc-decoder",
	"version": "1.0.2",
	"description": "A TypeScript library for encrypting and decrypting QRC lyrics format.",
	"main": "./dist/qrc_codec.mjs",
	"module": "./dist/qrc_codec.mjs",
	"types": "./dist/qrc_codec.d.mts",
	"exports": {
		".": {
			"require": "./dist/qrc_codec.cjs",
			"import": "./dist/qrc_codec.mjs",
			"types": "./dist/index.d.mts"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"test": "bun test",
		"typecheck": "bun tsgo -b",
		"prepublishOnly": "bun run build",
		"format": "bun biome format . --write"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/apoint123/qrc-decoder.git"
	},
	"keywords": [
		"qrc",
		"lyrics",
		"qqmusic",
		"lrc",
		"decoder",
		"encoder",
		"typescript"
	],
	"author": "apoint123<vpnzaph@outlook.com>",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/apoint123/qrc-decoder/issues"
	},
	"homepage": "https://github.com/apoint123/qrc-decoder",
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@types/bun": "^1.3.11",
		"@types/pako": "^2",
		"@typescript/native-preview": "^7.0.0-dev.20260406.1",
		"tsdown": "^0.21.7"
	},
	"dependencies": {
		"pako": "^2"
	},
	"packageManager": "pnpm@10.14.0"
}
